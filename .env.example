# Environment variables for Squeeze Strategy
# Copy this file to .env and fill in your values

# ============================================
# Email Configuration (SMTP)
# ============================================
# For Gmail: Use App Password, not regular password
# Get App Password: https://myaccount.google.com/apppasswords

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_RECIPIENTS=recipient1@example.com,recipient2@example.com

# ============================================
# LINE Notify Configuration
# ============================================
# Get token from: https://notify-bot.line.me/my/

LINE_TOKEN=your_line_token_here

# ============================================
# Market Data Configuration
# ============================================
# yfinance doesn't require API keys, but for other data sources:

# Alpha Vantage (optional, for additional data)
ALPHA_VANTAGE_API_KEY=

# Yahoo Finance settings
YF_CACHE_DIR=/tmp/yfinance_cache

# ============================================
# Strategy Configuration
# ============================================
# Default market and strategy

DEFAULT_MARKET=us
DEFAULT_STRATEGY=baseline

# ============================================
# Notification Settings
# ============================================

SEND_EMAIL=true
SEND_LINE=true
LINE_SUMMARY=true

# ============================================
# Paths
# ============================================

DATA_DIR=/Users/mylin/Documents/mylin102/squeeze-strategy/data
EXPORTS_DIR=/Users/mylin/Documents/mylin102/squeeze-strategy/exports
LOGS_DIR=/Users/mylin/Documents/mylin102/squeeze-strategy/logs

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
